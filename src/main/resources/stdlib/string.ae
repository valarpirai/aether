// Aether Standard Library - String Utilities
// String manipulation and helper functions

// join(array, separator) - Join array elements into string
fn join(array, separator) {
    if (len(array) == 0) {
        return ""
    }

    let result = str(array[0])
    let i = 1
    while (i < len(array)) {
        result = result + separator + str(array[i])
        i = i + 1
    }
    return result
}

// repeat(string, n) - Repeat string n times
fn repeat(string, n) {
    let result = ""
    let i = 0
    while (i < n) {
        result = result + string
        i = i + 1
    }
    return result
}

// reverse(string) - Reverse a string
fn reverse(string) {
    let chars = string.split("")
    let result = ""
    let i = len(chars) - 1
    while (i >= 0) {
        result = result + chars[i]
        i = i - 1
    }
    return result
}

// starts_with(string, prefix) - Check if string starts with prefix
fn starts_with(string, prefix) {
    let prefix_len = len(prefix)

    // Empty prefix always matches
    if (prefix_len == 0) {
        return true
    }

    // Prefix longer than string
    if (prefix_len > len(string)) {
        return false
    }

    // Compare character by character
    let chars = string.split("")
    let prefix_chars = prefix.split("")
    let i = 0
    while (i < prefix_len) {
        if (chars[i] != prefix_chars[i]) {
            return false
        }
        i = i + 1
    }

    return true
}

// ends_with(string, suffix) - Check if string ends with suffix
fn ends_with(string, suffix) {
    let suffix_len = len(suffix)
    let string_len = len(string)

    // Empty suffix always matches
    if (suffix_len == 0) {
        return true
    }

    // Suffix longer than string
    if (suffix_len > string_len) {
        return false
    }

    // Compare character by character from the end
    let chars = string.split("")
    let suffix_chars = suffix.split("")
    let i = 0
    while (i < suffix_len) {
        let string_idx = string_len - suffix_len + i
        if (chars[string_idx] != suffix_chars[i]) {
            return false
        }
        i = i + 1
    }

    return true
}
