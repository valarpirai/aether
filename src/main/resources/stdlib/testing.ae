// Aether Standard Library - Testing Framework
// Provides assertion helpers and a test runner

// assert_eq(actual, expected) - throws if actual != expected
fn assert_eq(actual, expected) {
    if (actual != expected) {
        throw "AssertionError: expected " + str(expected) + " but got " + str(actual)
    }
}

// assert_true(value) - throws if value is not truthy
fn assert_true(value) {
    if (!value) {
        throw "AssertionError: expected true but got " + str(value)
    }
}

// assert_false(value) - throws if value is truthy
fn assert_false(value) {
    if (value) {
        throw "AssertionError: expected false but got " + str(value)
    }
}

// assert_null(value) - throws if value is not null
fn assert_null(value) {
    if (type(value) != "null") {
        throw "AssertionError: expected null but got " + str(value)
    }
}

// assert_not_null(value) - throws if value is null
fn assert_not_null(value) {
    if (type(value) == "null") {
        throw "AssertionError: expected non-null value but got null"
    }
}

// expect_error(fn) - throws if the given function does NOT throw
fn expect_error(f) {
    let threw = false
    try {
        f()
    } catch(e) {
        threw = true
    }
    if (!threw) {
        throw "AssertionError: expected function to throw but it did not"
    }
}

// test(name, fn) - runs a test, prints PASS/FAIL, returns result dict
fn test(name, f) {
    let passed = false
    let err_msg = ""
    try {
        f()
        passed = true
    } catch(e) {
        err_msg = str(e)
    }
    if (passed) {
        println("[PASS] " + name)
    } else {
        println("[FAIL] " + name + ": " + err_msg)
    }
    return {"name": name, "passed": passed, "error": err_msg}
}

// test_summary(results) - prints summary of test results array
fn test_summary(results) {
    let total = len(results)
    let passed = 0
    let i = 0
    while (i < total) {
        if (results[i]["passed"]) {
            passed = passed + 1
        }
        i = i + 1
    }
    let failed = total - passed
    println("---")
    println("Tests: " + str(total) + " | Passed: " + str(passed) + " | Failed: " + str(failed))
}
