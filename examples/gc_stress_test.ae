// GC Stress Test - Verify Memory is Freed
// Before GC: Would consume 50+ MB
// After GC: Should stay under 1 MB

println("=== GC Stress Test ===")
println()

// Test 1: Heavy string concatenation
println("Test 1: String concatenation (10000 iterations)")
fn string_stress() {
    let result = ""
    let i = 0
    while (i < 10000) {
        result = result + "x"
        i = i + 1
    }
    return len(result)
}

let final_len = string_stress()
println("Final string length:", final_len)
println()

// Test 2: Array building
println("Test 2: Array operations (1000 iterations)")
fn array_stress() {
    let arr = []
    let i = 0
    while (i < 1000) {
        arr.push(i)
        i = i + 1
    }
    return len(arr)
}

let arr_len = array_stress()
println("Final array length:", arr_len)
println()

// Test 3: String splitting/joining
println("Test 3: String split/join (1000 iterations)")
fn split_join_stress() {
    let base = "a,b,c,d,e,f,g,h,i,j"
    let i = 0
    while (i < 1000) {
        let parts = base.split(",")
        let rejoined = join(parts, "-")
        i = i + 1
    }
    return i
}

let iterations = split_join_stress()
println("Completed iterations:", iterations)
println()

// Test 4: Nested operations
println("Test 4: Nested string operations")
fn nested_stress() {
    let result = ""
    for i in range(100) {
        let temp = ""
        for j in range(10) {
            temp = temp + str(j)
        }
        result = result + temp
    }
    return len(result)
}

let nested_len = nested_stress()
println("Nested result length:", nested_len)
println()

// Test 5: Weak references break Instance cycles
println("Test 5: Weak references for cycle-safe linked list")
struct Node {
    value
    next
}

fn make_list(n) {
    let head = null
    let i = n
    while (i > 0) {
        let node = Node { value: i, next: head }
        head = node
        i = i - 1
    }
    return head
}

let list = make_list(100)
println("Linked list head value:", list.value)

// Demonstrate weak refs — a Node can hold a back-pointer without owning it
let a = Node { value: 1, next: null }
let b = Node { value: 2, next: null }
let weak_a = make_weak(a)
b.next = weak_a
let back = upgrade_weak(b.next)
println("Back-pointer value:", back.value)
println("is_weak check:", is_weak(weak_a))
println()

println("=== GC Stress Test Complete ===")
println("If memory stayed low, GC is working!")

fn main() {}
