// GC Stress Test - Verify Memory is Freed
// Before GC: Would consume 50+ MB
// After GC: Should stay under 1 MB

println("=== GC Stress Test ===")
println()

// Test 1: Heavy string concatenation
println("Test 1: String concatenation (10000 iterations)")
fn string_stress() {
    let result = ""
    let i = 0
    while (i < 10000) {
        result = result + "x"
        i = i + 1
    }
    return len(result)
}

let final_len = string_stress()
println("Final string length:", final_len)
println()

// Test 2: Array building
println("Test 2: Array operations (1000 iterations)")
fn array_stress() {
    let arr = []
    let i = 0
    while (i < 1000) {
        arr.push(i)
        i = i + 1
    }
    return len(arr)
}

let arr_len = array_stress()
println("Final array length:", arr_len)
println()

// Test 3: String splitting/joining
println("Test 3: String split/join (1000 iterations)")
fn split_join_stress() {
    let base = "a,b,c,d,e,f,g,h,i,j"
    let i = 0
    while (i < 1000) {
        let parts = base.split(",")
        let rejoined = join(parts, "-")
        i = i + 1
    }
    return i
}

let iterations = split_join_stress()
println("Completed iterations:", iterations)
println()

// Test 4: Nested operations
println("Test 4: Nested string operations")
fn nested_stress() {
    let result = ""
    for i in range(100) {
        let temp = ""
        for j in range(10) {
            temp = temp + str(j)
        }
        result = result + temp
    }
    return len(result)
}

let nested_len = nested_stress()
println("Nested result length:", nested_len)
println()

println("=== GC Stress Test Complete ===")
println("If memory stayed low, GC is working! 🎉")
